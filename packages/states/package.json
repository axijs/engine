{
  "name": "@axi-engine/states",
  "version": "0.3.2",
  "description": "A minimal, type-safe state machine for the Axi Engine, designed for managing game logic and component states with a simple API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/axijs/engine.git",
    "directory": "packages/states"
  },
  "keywords": [
    "axi-engine",
    "typescript",
    "gamedev",
    "game-development",
    "game-engine",
    "state-machine",
    "finite-state-machine",
    "fsm",
    "state-management",
    "events"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm test",
    "test": "vitest run",
    "docs": "typedoc src/index.ts --out docs/api --options ../../typedoc.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@axijs/emitter": "^1.0.0",
    "@axijs/ensure": "^1.0.2",
    "@axi-engine/utils": "^0.3.0"
  }
}
